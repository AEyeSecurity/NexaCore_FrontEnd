# NexaCore — Variables de entorno del Frontend
# Copiar este archivo como .env y completar los valores reales
# IMPORTANTE: Las variables VITE_ son expuestas en el bundle del cliente.
#             Nunca incluir claves de servicio (service_role) aquí.

# Supabase — URL pública del proyecto
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Supabase — Anon key (clave pública, segura para exponer en cliente)
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# URL del backend NexaCore
# Desarrollo:  http://localhost:3001
# Producción:  https://api.tu-dominio-real.com
VITE_API_URL=http://localhost:3001
